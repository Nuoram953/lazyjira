# LazyJira Configuration Example
# Copy this file to .env and update with your Jira details

# Your Jira instance URL
JIRA_BASE_URL="https://your-domain.atlassian.net"

# Your Jira email address
JIRA_USERNAME="your-email@example.com"

# Your Jira API token (generate from Atlassian account settings)
JIRA_API_TOKEN="your-api-token-here"

# Optional: Specific board ID to focus on
JIRA_BOARD_ID="123"

# Optional: Maximum number of results to fetch (default: 50)
JIRA_MAX_RESULTS="50"

# Example JQL queries you might want to use:
# - Recently updated: "updated >= -7d ORDER BY updated DESC"
# - Assigned to you: "assignee = currentUser() ORDER BY updated DESC"
# - In progress: "status = 'In Progress' ORDER BY updated DESC"